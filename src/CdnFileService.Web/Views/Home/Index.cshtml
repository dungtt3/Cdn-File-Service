@model IReadOnlyList<CdnFileService.Application.DTOs.FileDto>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Dashboard</h1>
    <a class="btn btn-primary" asp-controller="FileManager" asp-action="Index">Open File Manager</a>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-bg-light">
            <div class="card-body">
                <h5 class="card-title">Total files</h5>
                <p class="display-6 mb-0">@ViewBag.TotalFiles</p>
            </div>
        </div>
    </div>
</div>

<h2 class="h5">Recently uploaded</h2>
@if (Model.Count == 0)
{
    <p class="text-muted">No files yet. Upload some through the File Manager.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Folder</th>
                    <th>Size</th>
                    <th>CDN URL</th>
                    <th>Uploaded</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td>@f.OriginalFileName</td>
                        <td><span class="badge text-bg-secondary">@f.Folder</span></td>
                        <td>@(f.Size / 1024) KB</td>
                        <td><code class="small">@f.CdnUrl</code></td>
                        <td>@f.CreatedDate.ToLocalTime().ToString("g")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
