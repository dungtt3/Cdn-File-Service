<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS hosting configuration. On publish, the SDK injects the correct <aspNetCore processPath/>.
  The request limits below allow uploads up to ~1 GB to match the application's MaxUploadSizeBytes.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\CdnFileService.Web.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
      <security>
        <requestFiltering>
          <!-- 1 GB in bytes -->
          <requestLimits maxAllowedContentLength="1073741824" />
        </requestFiltering>
      </security>
      <httpProtocol>
        <customHeaders>
          <!-- Drop any server-level X-Frame-Options (e.g. SAMEORIGIN) so the File Manager can be
               embedded as an iframe by trusted company sites. Framing is instead restricted by the
               Content-Security-Policy: frame-ancestors header set by the application. -->
          <remove name="X-Frame-Options" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>
