@{
    ViewData["Title"] = "File Manager";
    var elfinderVersion = "2.1.64";
    var jqueryUiVersion = "1.13.2";
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/@(jqueryUiVersion)/themes/smoothness/jquery-ui.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/elfinder/@(elfinderVersion)/css/elfinder.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/elfinder/@(elfinderVersion)/css/theme.min.css" />
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">File Manager</h1>
    <span class="text-muted small">
        @if (ViewBag.IsSuperAdmin == true)
        {
            <span class="badge text-bg-danger">Super-admin · all companies</span>
        }
        else if (!string.IsNullOrEmpty((string?)ViewBag.CompanyId))
        {
            <span class="badge text-bg-primary">Company @ViewBag.CompanyId</span>
        }
        · served from <code>@ViewBag.CdnRequestPath</code>
    </span>
</div>

<div id="elfinder">Loading file manager&hellip;</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/@(jqueryUiVersion)/jquery-ui.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/elfinder/@(elfinderVersion)/js/elfinder.min.js"></script>
    <script>
        $(function () {
            var isPicker = @(ViewBag.Picker == true ? "true" : "false");

            var opts = {
                url: '@Url.Content("~/el-finder/connector")',
                cssAutoLoad: false,
                height: 640,
                lang: 'en',
                commandsOptions: {
                    info: { custom: {} }
                }
            };

            if (isPicker) {
                // Embedded picker: return the chosen file's absolute URL to the parent window.
                opts.getFileCallback = function (file, fm) {
                    var url = (file && file.url) ? file.url : (file ? fm.url(file.hash) : '');
                    if (url && url.charAt(0) === '/') {
                        url = window.location.origin + url;
                    }
                    if (window.parent && window.parent !== window) {
                        window.parent.postMessage(
                            { source: 'cdn-filemanager', url: url, name: file ? file.name : '' }, '*');
                    }
                };
                opts.commandsOptions.getfile = { onlyURL: false, multiple: false, folders: false };
            }

            $('#elfinder').elfinder(opts);
        });
    </script>
}
