<?xml version="1.0" encoding="utf-8"?>
<!--
  Folder publish profile for IIS deployment.
  Usage: dotnet publish src/CdnFileService.Web -c Release /p:PublishProfile=IISProfile
  Then copy the contents of bin/Release/net8.0/publish to the IIS site folder.
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <PublishProvider>FileSystem</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish />
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <ExcludeApp_Data>true</ExcludeApp_Data>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishDir>bin\Release\net8.0\publish\</PublishDir>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
